<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Wellesley-Fresh-Staff</title>

		<link
			href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
			rel="stylesheet"
		/>

		<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
	</head>

	<body>
		<header class="p-3 text-bg-dark">
			<div class="container">
				<div
					class="d-flex flex-wrap align-items-center justify-content-center justify-content-lg-start"
				>
					<a
						href="/home"
						class="d-flex align-items-center mb-2 mb-lg-0 text-white text-decoration-none"
					>
						<svg
							class="bi me-2"
							width="40"
							height="32"
							role="img"
							aria-label="Bootstrap"
						>
							<use xlink:href="#bootstrap"></use>
						</svg>
					</a>
					<ul
						class="nav col-12 col-lg-auto me-lg-auto mb-2 justify-content-center mb-md-0"
					>
						<li>
							<a href="/staff" class="nav-link px-2 text-secondary"
								>Dashboard</a
							>
						</li>

						<li>
							<a href="#" class="nav-link px-2 text-white">Review Analytics</a>
						</li>
						<li><a href="#" class="nav-link px-2 text-white">Settings</a></li>
					</ul>
					

					<div class="d-flex gap-2">
						<p class="pt-3"><%= email %></p>
						<form action="/logout" method="POST">
							<button type="submit" class="btn btn-outline-light mt-2">
								Logout
							</button>
						</form>
					</div>
				</div>
			</div>
		</header>

		<div class="px-4 pt-5 my-5 text-center border-bottom">
			<h1 class="display-4 fw-bold text-body-emphasis mb-5">Staff Dashboard</h1>
		</div>

		<div class="container px-4 py-5" id="custom-cards">
			<h2 class="pb-2 border-bottom">Reviews</h2>
			<form class="col-12 col-lg-auto mb-3 mb-lg-0 me-lg-3" role="search">
						<input
							type="search"
							class="form-control form-control-light text-bg-light mt-3 mb-3"
							placeholder="Search for reviews"
							aria-label="Search"
						/>
			</form>
			<form method="GET" action="/staff" class="d-flex gap-3">
				<div class="dropdown">
					<button class="btn btn-outline-dark dropdown-toggle" type="button" data-bs-toggle="dropdown">Dining Hall</button>
					<ul class="dropdown-menu p-3" data-bs-auto-close="outside">
						<li>
							<label class="dropdown-item">
								<input type="checkbox" name="diningHall" value="Bates Hall"
									<%= selectedDiningHalls.includes("Bates Hall") ? "checked" : "" %>>
									Bates
							</label>
						</li>

						<li>
							<label class="dropdown-item">
								<input type="checkbox" name="diningHall" value="Tower Court"
										<%= selectedDiningHalls.includes("Tower Court") ? "checked" : "" %>>
										Tower
							</label>
						</li>

						<li>
							<label class="dropdown-item">
								<input type="checkbox" name="diningHall" value="Lulu Chow Wang"
										<%= selectedDiningHalls.includes("Lulu Chow Wang") ? "checked" : "" %>>
										Lulu
							</label>
						</li>
					</ul>
				</div>

				<button type="submit" class="btn btn-primary ">
					Apply filters
				</button>
			</form>
			<div class="column row-cols-1 align-items-stretch py-5">

				<% reviews.forEach(review => { %>
					<div class="col mb-3">
						<div
							class="card card-cover h-100 overflow-hidden text-bg-light "
						>	
							<div class="card-header">#<%= review.reviewID %></div>
							<div class="d-flex flex-column h-100 p-5 pb-3 text-dark">
								<p class=" ">⭐️<%= review.rating %></p>
								<p class=" display-6"><%= review.reviewText %></p>
								<ul class="d-flex list-unstyled mt-auto">
									<li class="me-auto">
										
									</li>
									<li class="d-flex align-items-center me-3">
										
										<small><%= review.diningHall %></small>
									</li>
									<li class="d-flex align-items-center">
										
										<small><%= new Date(review.dateUploaded).toLocaleDateString('en-US', {month: 'long', day: 'numeric'}) %></small>
									</li>
								</ul>
							</div>
						</div>
					</div>
				<% }) %>
				
			</div>
		</div>
	</body>
</html>
